{
  "name": "claude-credit-monitor",
  "displayName": "Claude Credit Monitor",
  "description": "Surveille ta consommation de crédits Claude en direct",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "claudeCredit.panel",
          "name": "Claude Credits"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeCredit.refresh",
        "title": "Claude Credits: Actualiser",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeCredit.setCookie",
        "title": "Claude Credits: Entrer le cookie de session"
      },
      {
        "command": "claudeCredit.openSettings",
        "title": "Claude Credits: Paramètres"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeCredit.refresh",
          "when": "view == claudeCredit.panel",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Claude Credit Monitor",
      "properties": {
        "claudeCredit.sessionCookie": {
          "type": "string",
          "default": "",
          "description": "Valeur du cookie sessionKey de claude.ai (DevTools > Application > Cookies > claude.ai > sessionKey)"
        },
        "claudeCredit.refreshInterval": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "Intervalle d'actualisation en secondes (minimum 5)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0"
  }
}
